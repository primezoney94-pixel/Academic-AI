# ============================================
#   AI ACADEMIC PLATFORM — Environment Config
# ============================================
# 1. Bu faylni .env.example dan .env ga nusxalang:
#    cp .env.example .env
# 2. Quyidagi barcha qiymatlarni to'ldiring
# ============================================

# ── Server ──────────────────────────────────
PORT=3001
NODE_ENV=development
# production da o'zgartiring:
BASE_URL=https://your-domain.com

# ── API Keys ────────────────────────────────
# Anthropic Console: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-api03-REPLACE_ME

# OpenAI Platform: https://platform.openai.com (DALL-E uchun, ixtiyoriy)
OPENAI_API_KEY=sk-REPLACE_ME

# ── Telegram ────────────────────────────────
# @BotFather dan olingan token
TELEGRAM_BOT_TOKEN=1234567890:REPLACE_ME

# ── Xavfsizlik ──────────────────────────────
# Admin endpoint uchun maxfiy kalit (ixtiyoriy, o'zingiz o'ylang)
ADMIN_SECRET_KEY=change-this-to-something-random

# ── CORS ────────────────────────────────────
# Ruxsat berilgan originlar (vergul bilan)
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ── Fayllar ─────────────────────────────────
# Fayllar saqlanadigan papka (avtomatik yaratiladi)
OUTPUT_DIR=./outputs
# Fayllar qancha vaqt saqlansin (millisekund) — 2 soat = 7200000
FILE_TTL_MS=7200000

# ── Rate Limiting ────────────────────────────
# 15 daqiqada nechta so'rov (har IP uchun)
RATE_LIMIT_MAX=20
